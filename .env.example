# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Wire-Pod Configuration
WIRE_POD_IP=192.168.1.100

# Vector Configuration
# Set to 'python' for pure python implementation if you have protobuf issues
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python

# Direct Connection Configuration (Optional - used if you don't want to use 'anki_vector.configure')
# Find these in your Wire-Pod web interface or robot console
VECTOR_IP=
VECTOR_NAME=
VECTOR_SERIAL=
VECTOR_GUID=
VECTOR_CERT_PATH=
